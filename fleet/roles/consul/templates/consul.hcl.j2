# Consul agent config — managed by Ansible
datacenter = "{{ consul_datacenter }}"
data_dir   = "/var/lib/consul"
log_level  = "INFO"

bind_addr  = "{{ '{{' }} GetInterfaceIP \"{{ consul_bind_interface }}\" {{ '}}' }}"
client_addr = "0.0.0.0"

{% if consul_server | default(false) %}
server           = true
bootstrap_expect = {{ consul_server_hosts | length | default(1) }}
ui_config {
  enabled = true
}
{% else %}
server = false
retry_join = [
{% for host in consul_server_hosts %}
  "{{ hostvars[host]['ansible_host'] | default(host) }}",
{% endfor %}
]
{% endif %}

{% if consul_encrypt_key %}
encrypt = "{{ consul_encrypt_key }}"
{% endif %}

# Service mesh (optional, for later)
connect {
  enabled = true
}

# Performance
performance {
  raft_multiplier = 1
}
